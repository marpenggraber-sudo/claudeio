<!-- components/message-bubble/message-bubble.wxml -->

<!-- 用户消息（右对齐）-->
<view wx:if="{{isUser}}" class="bubble-row bubble-user">
  <view class="bubble bubble-right">
    <text class="bubble-text">{{message.content}}</text>
  </view>
</view>

<!-- AI 消息（左对齐，带 Cyan 左边框）-->
<view wx:elif="{{isAI}}" class="bubble-row bubble-ai">
  <view class="bubble bubble-left">
    <view class="bubble-prefix">
      <text class="prefix-text">></text>
    </view>
    <text class="bubble-text ai-text">{{message.content}}</text>
  </view>
  <text class="timestamp">{{formattedTime}}</text>
</view>

<!-- 歌曲结果卡片 -->
<view wx:elif="{{isResult}}" class="bubble-row bubble-result">
  <view class="result-card">
    <!-- 封面 -->
    <view class="result-cover-wrap">
      <image
        wx:if="{{message.song.album.picUrl}}"
        class="result-cover"
        src="{{message.song.album.picUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="result-cover result-cover-placeholder">
        <text class="cover-icon">🎵</text>
      </view>
    </view>
    <!-- 信息 -->
    <view class="result-info">
      <text class="result-song-name">{{message.song.name}}</text>
      <text class="result-artist">{{message.song.artists ? message.song.artists[0].name : '未知'}}</text>
      <text class="result-album" wx:if="{{message.song.album.name}}">{{message.song.album.name}}</text>
    </view>
    <!-- 播放按钮 -->
    <view class="result-action" data-song="{{message.song}}" bindtap="onPlaySong">
      <text class="result-play-btn">▶</text>
    </view>
  </view>
</view>

<!-- 系统消息（居中灰色）-->
<view wx:elif="{{isSystem}}" class="bubble-row bubble-system">
  <text class="system-text">{{message.content}}</text>
</view>
