/* pages/settings/settings.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--bg-primary);
  padding: 24rpx;
}

/* 设置区块 */
.settings-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* 设置项 */
.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1px solid var(--border-color);
  gap: 16rpx;
}

.settings-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: var(--text-primary);
  flex-shrink: 0;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
}

.item-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: right;
}

.item-value.muted {
  color: var(--text-muted);
  font-size: 24rpx;
}

.item-value.logged-in {
  color: var(--color-green);
}

.item-value.powered-by {
  color: var(--color-cyan);
  font-size: 24rpx;
}

.item-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
  line-height: 1;
}

.bind-btn {
  font-size: 24rpx;
  color: var(--color-cyan);
  padding: 6rpx 16rpx;
  border: 1px solid var(--color-cyan);
  border-radius: 6rpx;
}

/* 播放模式按钮组 */
.playmode-btns {
  display: flex;
  gap: 12rpx;
}

.mode-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border: 1px solid var(--border-color);
  border-radius: 8rpx;
  background-color: var(--bg-secondary);
  transition: all 0.15s;
}

.mode-btn.active {
  border-color: var(--color-cyan);
  background-color: rgba(6, 182, 212, 0.1);
}

.mode-icon {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.mode-btn.active .mode-icon {
  color: var(--color-cyan);
}

.mode-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.mode-btn.active .mode-text {
  color: var(--color-cyan);
}

/* 音量滑块 */
.volume-slider {
  flex: 1;
  margin: 0;
}
