<view class="page-wrapper">
  <view class="glow-wrapper">
    <view class="container {{mode === 'register' ? 'register-mode' : ''}}">
      <view class="content login-content">
        
        <!-- 头部标识 -->
        <view class="header">
          <view class="logo-section">
            <view class="avatar" >
              <image class="avatar" src="https://img.yzcdn.cn/vant/cat.jpeg"></image>
            </view>
            <text class="logo-text">Melodio</text>
          </view>
          <view class="header-right">
            <text class="sys-status">状态: {{mode === 'register' ? '注册中' : '认证登录中'}}</text>
          </view>
        </view>

        <view class="divider"></view>

        <!-- 登录方式切换 -->
        <view class="method-tabs">
          <view class="tab {{loginMethod === 'qrcode' ? 'active' : ''}}" 
                bindtap="switchLoginMethod" data-value="qrcode">
            [ 扫码登录 ]
          </view>
          <view class="tab {{loginMethod === 'manual' ? 'active' : ''}}" 
                bindtap="switchLoginMethod" data-value="manual">
            [ 账号密码 ]
          </view>
        </view>

        <view class="divider"></view>

        <!-- 手动输入表单 -->
        <view wx:if="{{loginMethod === 'manual'}}" class="auth-form">
          <view class="input-group">
            <text class="label">账号</text>
            <view class="input-wrapper">
              <input class="sys-input" placeholder="输入账号..." placeholder-class="ph-style" bindinput="onAccountInput" value="{{account}}" />
            </view>
          </view>

          <view class="input-group">
            <text class="label">密码</text>
            <view class="input-wrapper">
              <input class="sys-input" placeholder="输入密码..." placeholder-class="ph-style" password="true" bindinput="onPasswordInput" value="{{password}}" />
            </view>
          </view>

          <view class="input-group">
            <text class="label">COOKIE 数据</text>
            <view class="input-wrapper">
              <textarea class="sys-textarea" placeholder="MUSIC_U=..." placeholder-class="ph-style" bindinput="onCookieInput" value="{{cookie}}" maxlength="-1" />
            </view>
          </view>

          <view class="action-group">
            <button class="sys-btn primary" bindtap="submit" loading="{{loading}}">
              {{mode === 'register' ? '注册' : '登录'}}
            </button>
          </view>
        </view>

        <!-- 二维码登录表单 -->
        <view wx:if="{{loginMethod === 'qrcode'}}" class="auth-form">
          <view class="qr-header">
            <text class="label">等待扫码操作</text>
          </view>

          <view class="qr-container">
            <view wx:if="{{!qrCodeImg}}" class="qr-loading">
              <text class="loading-text">{{ loading ? '正在生成二维码...' : '等待生成二维码' }}</text>
            </view>
            
            <image wx:if="{{qrCodeImg}}" class="qr-image" src="{{qrCodeImg}}" mode="aspectFit" />
            
            <view wx:if="{{qrCodeImg && qrCodeExpired}}" class="qr-overlay">
              <text class="expired-text">二维码已过期</text>
              <button class="sys-btn small" bindtap="generateQrCode">刷新</button>
            </view>
          </view>

          <view class="status-panel">
            <text class="status-indicator">♪♪</text>
            <text class="status-msg">{{qrCodeStatus || '等待初始化...'}}</text>
            <text class="status-indicator">♪♪</text>
          </view>

          <view class="action-group">
            <button class="sys-btn primary" bindtap="generateQrCode" loading="{{loading}}">
              {{qrCodeImg ? '刷新二维码' : '获取二维码'}}
            </button>
          </view>
        </view>

          <!-- 底部模式切换 -->
          <view class="footer-action" wx:if="{{loginMethod === 'manual'}}">
            <button class="sys-btn secondary" bindtap="switchMode">
              {{mode === 'register' ? '我要登录' : '没有账号？点击注册'}}
            </button>
          </view>

      </view>
    </view>
  </view>
</view>