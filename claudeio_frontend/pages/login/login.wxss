.page-wrapper {
  background-color: #000;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", "Inter", sans-serif;
}

.glow-wrapper {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
}

.container {
  width: 100%;
  height: 100%;
  background: #1a1f2e;
  border: 1px solid rgba(255, 255, 255, 0.15);
  position: relative;
  overflow: hidden;
  z-index: 1;
  display: flex;
  flex-direction: column;
  transition: background-color 0.4s ease;
}

/* 注册模式下的背景色（和谐的暗紫/暗紫红色调） */
.container.register-mode {
  background: #261e2e;
}

.container::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image: radial-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px);
  background-size: 12px 12px;
  background-position: 0 0;
  pointer-events: none;
  z-index: 0;
}

.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 20px;
  box-sizing: border-box;
}

/* 头部 Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  margin-top: 40px; 
}

.logo-section {
  display: flex;
  align-items: center;
}

.avatar {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #ccc;
  margin-right: 10px;
}

/* 修复了 Logo 颜色不可见的问题 */
.logo-text {
  font-size: 20px;
  letter-spacing: 2px;
  font-family: monospace;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
}

.sys-status {
  font-family: monospace;
  font-size: 10px;
  color: #4CAF50;
  letter-spacing: 1px;
}

.divider {
  height: 1px;
  background-color: rgba(255, 255, 255, 0.05);
  margin: 15px 0;
}

/* 标签切换 */
.method-tabs {
  display: flex;
  gap: 20px;
  padding: 5px 0;
}

.tab {
  font-family: monospace;
  font-size: 13px;
  color: #555;
  cursor: pointer;
  transition: color 0.2s;
}

.tab.active {
  color: #fff;
  text-shadow: 0 0 5px rgba(255,255,255,0.3);
}

/* 表单主体 */
.auth-form {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 10px;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.label {
  font-family: monospace;
  font-size: 12px;
  color: #888;
  letter-spacing: 1px;
}

.input-wrapper {
  background-color: rgba(0,0,0,0.4);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  padding: 10px 12px;
}

.sys-input, .sys-textarea {
  width: 100%;
  color: #e8eaed;
  font-size: 14px;
  line-height: 1.5;
  background: transparent;
  border: none;
}

.sys-textarea {
  height: 80px; /* 设定固定高度值，阻断其拉伸父容器的可能 */
  font-family: monospace;
  font-size: 11px;
}

.ph-style {
  color: #555;
}


/* 按钮通用重置与统一样式 */
.sys-btn {
  width: 100%;
  background: transparent;
  padding: 12px;
  margin: 0;
  border-radius: 6px;
  font-family: monospace;
  font-size: 12px;
  letter-spacing: 1px;
  text-align: center;
  box-sizing: border-box;
}

.sys-btn::after {
  display: none;
}

.sys-btn.primary {
  background-color: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
}

.sys-btn.primary:active {
  background-color: rgba(255,255,255,0.12);
}

.sys-btn.secondary {
  border: none; /* 移除虚线边框 */
  background: transparent; /* 确保背景完全透明 */
  color: #888;
}

.sys-btn.secondary:active {
  opacity: 0.6; /* 用户点击时文字变暗，提示触发了点击事件 */
}

.sys-btn.small {
  width: auto;
  padding: 6px 16px;
  font-size: 10px;
  background-color: rgba(0,0,0,0.8);
  border: 1px solid rgba(255,255,255,0.3);
  color: #fff;
}

/* 二维码容器 */
.qr-container {
  width: 200px;
  height: 200px;
  margin: 0 auto;
  background-color: rgba(0,0,0,0.4);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.qr-image {
  width: 180px;
  height: 180px;
}

.qr-loading {
  font-family: monospace;
  font-size: 10px;
  color: #555;
  animation: blink 1.5s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.qr-overlay {
  position: absolute;
  inset: 0;
  background: rgba(26, 31, 46, 0.9);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 15px;
  border-radius: 6px;
}

.expired-text {
  font-family: monospace;
  font-size: 12px;
  color: #ff4444;
}

/* 状态模拟面板 */
.status-panel {
  background-color: rgba(0,0,0,0.6);
  border: 1px solid rgba(255,255,255,0.05);
  padding: 10px;
  border-radius: 6px;
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
  justify-content: center;
}

.status-indicator {
  color: #00bcd4;
  font-family: monospace;
  font-size: 12px;
}

.status-msg {
  color: #ccc;
  font-family: monospace;
  font-size: 11px;
}

.footer-action {
  margin-top: auto;
  padding-top: 20px;
}