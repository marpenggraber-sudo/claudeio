/* 页面容器 - 米白色背景 */
.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: #f5f5dc;
  position: relative;
  overflow: hidden;
}

/* 卡片容器 - 毛玻璃效果 */
.card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(26, 31, 46, 0.7);
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3),
              0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  position: relative;
  z-index: 1;
  animation: slideUp 0.6s ease-out;
  overflow: hidden;
}

/* 点状背景图案 */
.card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px);
  background-size: 12px 12px;
  background-position: 0 0;
  pointer-events: none;
  z-index: 0;
}

/* 动态旋转光晕效果 */
.card::after {
  content: "";
  position: absolute;
  inset: -150rpx;
  background: rgba(0, 188, 212, 0.3);
  filter: blur(80rpx);
  opacity: 0.6;
  z-index: -1;
  animation: rotateGlow 12s linear infinite;
  pointer-events: none;
}

@keyframes rotateGlow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.logo-icon {
  font-size: 80rpx;
  animation: bounce 2s ease-in-out infinite;
  filter: drop-shadow(0 0 10rpx rgba(0, 188, 212, 0.5));
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 6rpx;
  color: #fff;
  text-shadow: 0 0 20rpx rgba(0, 188, 212, 0.8),
               0 0 40rpx rgba(0, 188, 212, 0.5),
               0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  filter: drop-shadow(0 0 10rpx rgba(255, 255, 255, 0.3));
}

.subtitle {
  font-size: 24rpx;
  color: #888;
  text-align: center;
  letter-spacing: 2rpx;
}

/* ============ 登录方式切换 ============ */
.method-switch {
  display: flex;
  gap: 24rpx;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  position: relative;
  z-index: 1;
  justify-content: center;
  max-width: 500rpx;
  margin: 0 auto;
}

.switch-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 32rpx;
  border-radius: 12rpx;
  background: transparent;
  color: #888;
  font-size: 26rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  min-width: 200rpx;
}

.switch-item.active {
  background: linear-gradient(135deg, rgba(0, 188, 212, 0.25), rgba(0, 150, 180, 0.25));
  color: #00bcd4;
  box-shadow: 0 0 20rpx rgba(0, 188, 212, 0.4),
              0 4rpx 12rpx rgba(0, 188, 212, 0.2);
  transform: translateY(-2rpx);
}

.switch-icon {
  font-size: 40rpx;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

.switch-item.active .switch-icon {
  filter: grayscale(0%);
  transform: scale(1.1);
}

.switch-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ============ 表单区域 ============ */
.form-section {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  position: relative;
  z-index: 1;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 输入组 */
.input-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label-with-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.input-label {
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
  padding-left: 8rpx;
  letter-spacing: 1rpx;
}

.tip-badge {
  font-size: 20rpx;
  color: #00bcd4;
  padding: 4rpx 12rpx;
  background: rgba(0, 188, 212, 0.1);
  border-radius: 20rpx;
  border: 1px solid rgba(0, 188, 212, 0.3);
  cursor: pointer;
  transition: all 0.3s ease;
}

.tip-badge:active {
  background: rgba(0, 188, 212, 0.2);
  transform: scale(0.95);
}

.input-hint {
  font-size: 20rpx;
  color: #666;
  padding-left: 8rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 输入框样式 */
.input-field {
  width: 100%;
  padding: 28rpx 32rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #00bcd4;
  background: rgba(0, 0, 0, 0.6);
  box-shadow: 0 0 0 2rpx rgba(0, 188, 212, 0.2);
}

.input-field::placeholder {
  color: #555;
}

.textarea-field {
  min-height: 120rpx;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace;
  font-size: 22rpx;
}

/* ============ 网易云登录专属样式 ============ */
.netease-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.netease-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #00bcd4;
  letter-spacing: 2rpx;
  text-shadow: 0 0 10rpx rgba(0, 188, 212, 0.5);
}

.netease-subtitle {
  font-size: 22rpx;
  color: #888;
  letter-spacing: 1rpx;
}

/* 登录类型切换 */
.login-type-switch {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.type-item {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  color: #888;
  font-size: 24rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.type-item.active {
  background: rgba(0, 188, 212, 0.2);
  border-color: #00bcd4;
  color: #00bcd4;
  box-shadow: 0 0 10rpx rgba(0, 188, 212, 0.3);
}

/* 安全提示 */
.security-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: rgba(0, 188, 212, 0.1);
  border-left: 3px solid #00bcd4;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

/* ============ 按钮区域 ============ */
.button-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
  position: relative;
  z-index: 1;
}

button {
  width: 100%;
  padding: 28rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  letter-spacing: 2rpx;
}

/* 主操作按钮 */
.primary-button {
  background: #00bcd4;
  color: #000;
  font-weight: bold;
  box-shadow: 0 0 20rpx rgba(0, 188, 212, 0.4);
}

.primary-button:active {
  transform: scale(0.98);
  box-shadow: 0 0 10rpx rgba(0, 188, 212, 0.3);
}

/* 发光按钮（网易云登录专用） */
.glow-button {
  animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 20rpx rgba(0, 188, 212, 0.4);
  }
  50% {
    box-shadow: 0 0 40rpx rgba(0, 188, 212, 0.8),
                0 0 60rpx rgba(0, 188, 212, 0.4);
  }
}

.button-hint {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  margin-top: 8rpx;
}

/* 次要按钮 */
.secondary-button {
  background: transparent;
  color: #888;
  border: 1px solid rgba(255, 255, 255, 0.1) !important;
  box-shadow: none;
  font-size: 24rpx;
}

.secondary-button:active {
  background: rgba(255, 255, 255, 0.05);
  color: #00bcd4;
}

/* 底部区域 */
.bottom-section {
  position: relative;
  z-index: 1;
}

/* 加载状态 */
button[loading] {
  opacity: 0.7;
}

/* 按钮波纹效果 */
button::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

button:active::after {
  width: 600rpx;
  height: 600rpx;
}

/* ============ 验证码登录专属样式 ============ */
.captcha-input-wrapper {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.captcha-input {
  flex: 1;
}

.captcha-button {
  width: 180rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: rgba(0, 188, 212, 0.2);
  color: #00bcd4;
  border: 1px solid rgba(0, 188, 212, 0.3);
  transition: all 0.3s ease;
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
}

.captcha-button:active {
  background: rgba(0, 188, 212, 0.3);
  transform: scale(0.98);
}

.captcha-button.disabled {
  opacity: 0.5;
  color: #666;
  background: rgba(0, 0, 0, 0.3);
  border-color: rgba(255, 255, 255, 0.1);
}

/* ============ 二维码登录专属样式 ============ */
.qrcode-container {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.qrcode-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-text {
  color: #888;
  font-size: 24rpx;
}

.qrcode-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.qrcode-expired {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  border-radius: 16rpx;
}

.expired-text {
  color: #ff5252;
  font-size: 28rpx;
  font-weight: 500;
}

.refresh-button {
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  background: rgba(0, 188, 212, 0.2);
  color: #00bcd4;
  border: 1px solid rgba(0, 188, 212, 0.3);
  border-radius: 12rpx;
  font-size: 24rpx;
}

.refresh-button:active {
  background: rgba(0, 188, 212, 0.3);
}

.qrcode-status {
  text-align: center;
  margin: 20rpx 0;
  min-height: 40rpx;
}

.status-text {
  color: #00bcd4;
  font-size: 26rpx;
  font-weight: 500;
}

.status-text.waiting {
  color: #888;
}

.status-text.scanned {
  color: #4caf50;
}

.status-text.success {
  color: #00bcd4;
}
